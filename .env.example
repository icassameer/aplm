# ─── ICA CRM — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Required: Generate with → openssl rand -base64 64
SESSION_SECRET=replace_with_256bit_random_string_minimum_32_chars

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://ica_user:YourStrongPassword123!@localhost:5432/ica_crm

# Required: From platform.openai.com
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxx

# Required in production
NODE_ENV=production

# Optional: Comma-separated allowed origins (default: https://crm.icaweb.in)
ALLOWED_ORIGINS=https://crm.icaweb.in

# Optional: Override default port (default: 5000)
# PORT=5000
